{
  "name": "dployr-base",
  "type": "module",
  "scripts": {
    "dev": "node scripts/sync-ip.mjs && concurrently \"npm run dev:app\" \"npm run dev:docs\"",
    "dev:vector": "docker compose -f docker-compose.dev.yml up",
    "dev:app": "node scripts/sync-ip.mjs && cross-env NODE_ENV=development node --import tsx src/index.ts",
    "dev:app:test": "cross-env NODE_ENV=test node --import tsx src/index.ts",
    "dev:docs": "serve docs -l 9099",
    "dev:logs": "serve pages/logs -l 8787",
    "build": "tsc --noEmit",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:api": "cross-env NODE_ENV=test node --import tsx --test tests/integration/index.test.ts",
    "test:bash": "bats tests/bash/install.bats tests/bash/install-traefik.bats",
    "test": "pnpm run test:unit && pnpm run test:api",
    "type": "module"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.1.2",
    "@octokit/rest": "^22.0.1",
    "buffer": "^6.0.3",
    "hono": "^4.8.4",
    "jose": "^6.1.2",
    "otpauth": "^9.5.0",
    "pg": "^8.13.1",
    "redis": "^5.10.0",
    "smol-toml": "^1.5.2",
    "tsx": "^4.19.2",
    "ua-parser-js": "^2.0.10",
    "ulid": "^3.0.1",
    "ws": "^8.18.0",
    "zod": "^4.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@embedded-postgres/linux-x64",
      "@embedded-postgres/linux-x64-alpine",
      "@embedded-postgres/darwin-arm64",
      "@embedded-postgres/darwin-x64",
      "@embedded-postgres/windows-x64"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/ua-parser-js": "^0.7.39",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "embedded-postgres": "18.3.0-beta.17",
    "redis-memory-server": "^0.16.1",
    "serve": "^14.2.0",
    "typescript": "^5.6.3"
  }
}
