{
  "name": "dployr-base",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:app\" \"npm run dev:docs\"",
    "dev:app": "cross-env NODE_ENV=development node --import tsx src/index.ts",
    "dev:app:test": "cross-env NODE_ENV=test node --import tsx src/index.ts",
    "dev:docs": "serve docs -l 9099",
    "build": "tsc --noEmit",
    "test:api": "cross-env NODE_ENV=test node --import tsx --test tests/integration/index.ts",
    "type": "module"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.1.2",
    "@octokit/rest": "^22.0.1",
    "buffer": "^6.0.3",
    "hono": "^4.8.4",
    "jose": "^6.1.2",
    "otpauth": "^9.5.0",
    "pg": "^8.13.1",
    "redis": "^5.10.0",
    "smol-toml": "^1.5.2",
    "tsx": "^4.19.2",
    "ulid": "^3.0.1",
    "ws": "^8.18.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "serve": "^14.2.0",
    "typescript": "^5.6.3"
  }
}
